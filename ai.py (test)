import os
import tkinter as tk
from tkinter import filedialog, scrolledtext, messagebox
import threading
import time
import re
import datetime
import platform
from PIL import Image, ImageTk

class LocalAssistantApp:
    def __init__(self, root):
        self.root = root
        self.root.title("Smart Local Assistant")
        self.root.geometry("700x800")
        self.root.configure(bg="#1e1e1e")

        self.attached_file_path = None
        self.setup_ui()

    def setup_ui(self):
        # 1. Chat Logs Area
        self.chat_display = scrolledtext.ScrolledText(
            self.root, wrap=tk.WORD, state='disabled',
            bg="#2d2d2d", fg="#ffffff", insertbackground="white",
            font=("Consolas", 11), bd=0, highlightthickness=1, highlightbackground="#3f3f3f"
        )
        self.chat_display.pack(padx=15, pady=(15, 5), fill=tk.BOTH, expand=True)

        # Configure text colors
        self.chat_display.tag_config("user", foreground="#0098ff", font=("Consolas", 11, "bold"))
        self.chat_display.tag_config("bot", foreground="#00ffcc", font=("Consolas", 11))
        self.chat_display.tag_config("system", foreground="#aaaaaa", font=("Consolas", 10, "italic"))
        self.chat_display.tag_config("code", foreground="#f8f8f2", background="#333333", font=("Consolas", 10))

        # 2. File Attachment Status Label
        self.file_label = tk.Label(
            self.root, text="No files or images attached.",
            bg="#1e1e1e", fg="#aaaaaa", font=("Arial", 10)
        )
        self.file_label.pack(padx=15, pady=2, anchor="w")

        # 3. Bottom Dock Control Container
        bottom_frame = tk.Frame(self.root, bg="#1e1e1e")
        bottom_frame.pack(padx=15, pady=(5, 15), fill=tk.X, anchor="s")

        # Attachment Button
        self.attach_btn = tk.Button(
            bottom_frame, text="📎 Attach", command=self.select_file,
            bg="#3a3a3a", fg="#ffffff", activebackground="#4a4a4a", activeforeground="#ffffff",
            bd=0, padx=10, pady=8, font=("Arial", 10, "bold"), cursor="hand2"
        )
        self.attach_btn.pack(side=tk.LEFT, padx=(0, 10))

        # Text Input field
        self.input_field = tk.Entry(
            bottom_frame, bg="#2d2d2d", fg="#ffffff", insertbackground="white",
            bd=0, highlightthickness=1, highlightbackground="#3f3f3f",
            font=("Arial", 12), width=40
        )
        self.input_field.pack(side=tk.LEFT, fill=tk.X, expand=True, ipady=6)
        self.input_field.bind("<Return>", lambda event: self.send_message())

        # Send Button
        self.send_btn = tk.Button(
            bottom_frame, text="Send", command=self.send_message,
            bg="#007acc", fg="#ffffff", activebackground="#0098ff", activeforeground="#ffffff",
            bd=0, padx=15, pady=8, font=("Arial", 10, "bold"), cursor="hand2"
        )
        self.send_btn.pack(side=tk.RIGHT, padx=(10, 0))

    def select_file(self):
        file_path = filedialog.askopenfilename(
            title="Select a File",
            filetypes=[("All Files", "*.*"), ("Text/Code Files", "*.py *.java *.txt *.json *.md *.html *.css *.js"), ("Images", "*.png *.jpg *.jpeg *.webp")]
        )
        if file_path:
            self.attached_file_path = file_path
            filename = os.path.basename(file_path)
            self.file_label.config(text=f"Attached: {filename}", fg="#00ff66")

    def append_to_chat(self, sender, text, tag):
        self.chat_display.config(state='normal')
        self.chat_display.insert(tk.END, f"{sender}: ", tag)
        
        # Check if text contains "code" markers
        if "```" in text:
            parts = text.split("```")
            for i, part in enumerate(parts):
                if i % 2 == 1: # This is inside code block
                    self.chat_display.insert(tk.END, part, "code")
                else:
                    self.chat_display.insert(tk.END, part)
        else:
            self.chat_display.insert(tk.END, text)
            
        self.chat_display.insert(tk.END, "\n\n")
        self.chat_display.config(state='disabled')
        self.chat_display.yview(tk.END)

    def send_message(self):
        user_text = self.input_field.get().strip()

        if not user_text and not self.attached_file_path:
            return

        if user_text:
            self.append_to_chat("You", user_text, "user")
        if self.attached_file_path:
            self.append_to_chat("System", f"[Working with file: {os.path.basename(self.attached_file_path)}]", "system")

        self.input_field.delete(0, tk.END)
        self.send_btn.config(state="disabled")

        threading.Thread(target=self.process_request, args=(user_text, self.attached_file_path), daemon=True).start()

        self.attached_file_path = None
        self.file_label.config(text="No files or images attached.", fg="#aaaaaa")

    def process_request(self, prompt, file_path):
        time.sleep(0.3)
        prompt_lower = prompt.lower()
        response = ""

        # --- SMART LOGIC ENGINE ---
        
        # 1. Math Evaluation
        if re.match(r'^[\d\s\+\-\*\/\(\)\.]+$', prompt) and any(c in prompt for c in "+-*/"):
            try:
                result = eval(prompt)
                response = f"The result of '{prompt}' is: **{result}**"
            except:
                response = "I tried to calculate that, but the expression seems invalid."

        # 2. File Analysis
        elif file_path and ("read" in prompt_lower or "content" in prompt_lower or "show" in prompt_lower or not prompt):
            try:
                ext = os.path.splitext(file_path)[1].lower()
                if ext in ['.txt', '.py', '.java', '.json', '.md', '.html', '.css', '.js']:
                    with open(file_path, "r", encoding="utf-8", errors="ignore") as f:
                        content = f.read()
                        word_count = len(content.split())
                        char_count = len(content)
                        response = f"I've analyzed **{os.path.basename(file_path)}**.\n"
                        response += f"Stats: {word_count} words, {char_count} characters.\n\n"
                        response += f"Content Preview:\n```\n{content[:1000]}{'...' if len(content) > 1000 else ''}\n```"
                else:
                    response = f"I see the file '{os.path.basename(file_path)}', but it's a binary or image file. I can't read its text content, but I can confirm it exists and is {os.path.getsize(file_path)} bytes."
            except Exception as e:
                response = f"I ran into an error reading the file: {e}"

        # 3. File Search
        elif file_path and "find" in prompt_lower:
            search_term = prompt_lower.replace("find", "").strip()
            if search_term:
                try:
                    with open(file_path, "r", encoding="utf-8", errors="ignore") as f:
                        lines = f.readlines()
                        matches = [f"Line {i+1}: {line.strip()}" for i, line in enumerate(lines) if search_term in line.lower()]
                        if matches:
                            response = f"I found '{search_term}' in **{os.path.basename(file_path)}** at these locations:\n\n" + "\n".join(matches[:10])
                            if len(matches) > 10: response += f"\n...and {len(matches)-10} more matches."
                        else:
                            response = f"I couldn't find '{search_term}' in that file."
                except:
                    response = "I couldn't search through that file."

        # 4. System Info
        elif "system" in prompt_lower or "info" in prompt_lower:
            response = f"System Info:\n- OS: {platform.system()} {platform.release()}\n- Time: {datetime.datetime.now().strftime('%H:%M:%S')}\n- Python: {platform.python_version()}"

        # 5. General Conversations
        elif any(word in prompt_lower for word in ["hello", "hi", "hey"]):
            response = "Hello! I'm your local assistant. I can calculate math, read/search files you attach, and give you system info—all without any external AI models."
        elif "time" in prompt_lower:
            response = f"The current local time is {datetime.datetime.now().strftime('%I:%M %p')}."
        elif "help" in prompt_lower:
            response = "You can ask me to:\n1. Solve math (e.g., '25 * 4')\n2. Read an attached file ('show content')\n3. Find text in a file ('find keyword')\n4. Tell you the 'time' or 'system info'."
        
        # 6. Default Fallback
        else:
            if prompt:
                response = f"I'm a rule-based assistant and don't have a full AI brain, so I'm not sure how to respond to '{prompt}'. \n\nTry asking for 'help' to see what I can do!"
            else:
                response = "How can I help you today?"

        self.root.after(0, self.append_to_chat, "Assistant", response, "bot")
        self.root.after(0, lambda: self.send_btn.config(state="normal"))

if __name__ == "__main__":
    root = tk.Tk()
    app = LocalAssistantApp(root)
    root.mainloop()
