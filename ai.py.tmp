import os
import tkinter as tk
from tkinter import filedialog, scrolledtext, messagebox
import threading
import time
import re
import datetime
import platform
import math
import random
import json
import urllib.request
import urllib.parse
import subprocess
import webbrowser
import html
from html.parser import HTMLParser

try:
    from textblob import TextBlob as TB
except ImportError:
    TB = None

# Optional Image Support
try:
    from PIL import Image, ImageTk, ImageStat
    HAS_PIL = True
except ImportError:
    HAS_PIL = False

# Browser automation for web scraping (no APIs needed)
try:
    from selenium import webdriver
    from selenium.webdriver.common.by import By
    from selenium.webdriver.support.ui import WebDriverWait
    from selenium.webdriver.support import expected_conditions as EC
    from selenium.webdriver.chrome.options import Options
    HAS_SELENIUM = True
except ImportError:
    HAS_SELENIUM = False

# Beautiful Soup for parsing
try:
    from bs4 import BeautifulSoup
    HAS_BS4 = True
except ImportError:
    HAS_BS4 = False

class WebEngine:
    def __init__(self):
        self.user_agent = 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/121.0.0.0 Safari/537.36'
        self.driver = None
        self.search_cache = {}

    def _get_driver(self):
        if not HAS_SELENIUM:
            return None
        try:
            if self.driver is None:
                options = Options()
                options.add_argument("--headless")
                options.add_argument("--disable-blink-features=AutomationControlled")
                options.add_argument(f"user-agent={self.user_agent}")
                options.add_argument("--disable-gpu")
                options.add_argument("--no-sandbox")
                self.driver = webdriver.Chrome(options=options)
            return self.driver
        except:
            return None

    def _fetch(self, url, headers=None):
        request_headers = {'User-Agent': self.user_agent}
        if headers:
            request_headers.update(headers)
        try:
            req = urllib.request.Request(url, headers=request_headers)
            with urllib.request.urlopen(req, timeout=10) as response:
                return response.read().decode('utf-8', errors='ignore')
        except:
            return ""

    def _search_google(self, query):
        try:
            driver = self._get_driver()
            if not driver:
                return []
            
            driver.get(f"https://www.google.com/search?q={urllib.parse.quote(query)}")
            time.sleep(2)
            
            results = []
            soup = BeautifulSoup(driver.page_source, 'html.parser')
            
            for item in soup.find_all('div', class_='g')[:5]:
                title_elem = item.find('h3')
                url_elem = item.find('a')
                desc_elem = item.find('div', class_='VwiC3b')
                
                if title_elem and url_elem and url_elem.get('href'):
                    title = title_elem.get_text(strip=True)
                    url = url_elem.get('href').split('?')[0] if '?' in url_elem.get('href') else url_elem.get('href')
                    desc = desc_elem.get_text(strip=True) if desc_elem else ""
                    
                    if title and url and not url.startswith('/'):
                        results.append({"title": title, "url": url, "description": desc})
            
            return results
        except Exception as e:
            return []

    def _search_fallback(self, query):
        try:
            encoded = urllib.parse.quote(query)
            page = self._fetch(f"https://search.brave.com/search?q={encoded}")
            if page and HAS_BS4:
                soup = BeautifulSoup(page, 'html.parser')
                results = []
                for item in soup.find_all('div', class_='snippet')[:5]:
                    title = item.find('a', class_='result-header')
                    desc = item.find('p', class_='snippet')
                    if title and desc:
                        results.append({
                            "title": title.get_text(strip=True),
                            "url": title.get('href', ''),
                            "description": desc.get_text(strip=True)
                        })
                return results
            return []
        except:
            return []

    def search(self, query):
        try:
            if query in self.search_cache:
                return self.search_cache[query]
            
            encoded = urllib.parse.quote(query)
            
            # Try browser-based search first
            results = []
            if HAS_SELENIUM:
                results = self._search_google(query)
            
            if not results:
                results = self._search_fallback(query)

            # Fetch Wikipedia for context
            wiki_res = ""
            try:
                w_search = json.loads(self._fetch(f"https://en.wikipedia.org/w/api.php?action=opensearch&search={encoded}&limit=1&format=json"))
                if w_search[1]:
                    title = w_search[1][0]
                    w_sum = json.loads(self._fetch(f"https://en.wikipedia.org/api/rest_v1/page/summary/{urllib.parse.quote(title.replace(' ', '_'))}"))
                    if w_sum.get("type") != "disambiguation":
                        wiki_res = w_sum.get("extract", "")
            except:
                pass

            cache_result = (wiki_res, results)
            self.search_cache[query] = cache_result
            return cache_result
        except:
            return None, []
    
    def close(self):
        if self.driver:
            try:
                self.driver.quit()
            except:
                pass
            self.driver = None

